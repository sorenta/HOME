{
    "name": "@n8n-as-code/skills",
    "version": "1.7.0",
    "description": "AI Agent skills library for n8nac (internal — use npx n8nac skills)",
    "type": "module",
    "license": "MIT",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "scripts": {
        "prebuild": "node ../../scripts/ensure-n8n-cache.cjs && node ../../scripts/stamp-n8n-version.cjs && node ../../scripts/generate-n8n-index.cjs && node ../../scripts/download-complete-docs.cjs && node ../../scripts/build-complete-index.cjs && node ../../scripts/enrich-nodes-technical.cjs && node ../../scripts/build-knowledge-index.cjs && node ../../scripts/build-workflow-index.cjs",
        "build": "tsc -b",
        "postbuild": "mkdir -p dist/assets && cp src/assets/*.json dist/assets/",
        "clean": "rm -rf dist tsconfig.tsbuildinfo",
        "test": "node --experimental-vm-modules ../../node_modules/.bin/jest",
        "build:adapters": "node scripts/build-skill-adapters.js"
    },
    "dependencies": {
        "@modelcontextprotocol/sdk": "^1.27.1",
        "@n8n-as-code/transformer": "1.0.2",
        "chalk": "^4.1.2",
        "commander": "^11.1.0",
        "flexsearch": "^0.8.212",
        "zod": "^3.22.4"
    },
    "devDependencies": {
        "@types/flexsearch": "^0.7.6",
        "@types/fs-extra": "^11.0.4",
        "@types/jest": "^29.5.11",
        "@types/node": "^20.10.0",
        "fast-glob": "^3.3.3",
        "fs-extra": "^7.0.1",
        "jest": "^29.7.0",
        "simple-git": "^3.30.0",
        "ts-jest": "^29.1.1",
        "typescript": "^5.3.3"
    },
    "files": [
        "dist/"
    ],
    "repository": {
        "type": "git",
        "url": "https://github.com/EtienneLescot/n8n-as-code",
        "directory": "packages/skills"
    },
    "publishConfig": {
        "access": "public"
    }
}
