{
    "name": "n8nac",
    "version": "1.5.5",
    "description": "Unified CLI for n8n-as-code — manage workflows and access AI tools",
    "main": "./dist/lib.js",
    "types": "./dist/lib.d.ts",
    "bin": {
        "n8nac": "./dist/index.js"
    },
    "type": "module",
    "license": "MIT",
    "scripts": {
        "copy-assets": "mkdir -p dist/core/assets && cp src/core/assets/n8n-workflows.d.ts dist/core/assets/",
        "build": "tsc -b && npm run copy-assets && chmod +x dist/index.js",
        "watch": "tsc -b -w",
        "clean": "rm -rf dist tsconfig.tsbuildinfo",
        "test": "npm run test:unit",
        "test:unit": "vitest run tests/unit tests/scenarios tests/integration/*.test.ts",
        "test:integration": "npm run build && node tests/integration/run-live-sync-tests.mjs",
        "test:all": "npm run test:unit && npm run test:integration",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage"
    },
    "dependencies": {
        "@n8n-as-code/skills": "1.7.0",
        "@n8n-as-code/transformer": "1.0.2",
        "@types/json-stable-stringify": "^1.1.0",
        "axios": "^1.6.0",
        "chalk": "^5.3.0",
        "chokidar": "^3.5.3",
        "cli-table3": "^0.6.3",
        "commander": "^11.1.0",
        "conf": "^15.0.2",
        "deep-equal": "^2.2.3",
        "diff": "^5.1.0",
        "dotenv": "^16.3.1",
        "inquirer": "^13.1.0",
        "json-stable-stringify": "^1.3.0",
        "log-update": "^6.0.0",
        "ora": "^7.0.1",
        "zod": "^3.22.4"
    },
    "devDependencies": {
        "@types/deep-equal": "^1.0.4",
        "@types/diff": "^5.0.9",
        "@types/inquirer": "^9.0.9",
        "@types/node": "^20.10.6",
        "@vitest/coverage-v8": "^1.1.0",
        "typescript": "^5.3.3",
        "vitest": "^1.1.0"
    },
    "files": [
        "dist/"
    ],
    "repository": {
        "type": "git",
        "url": "https://github.com/EtienneLescot/n8n-as-code",
        "directory": "packages/cli"
    },
    "publishConfig": {
        "access": "public"
    }
}
