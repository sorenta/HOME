{
  "name": "n8n-as-code",
  "displayName": "n8n as code",
  "description": "Edit your n8n workflows directly in VS Code with AI assistance.",
  "version": "1.34.0",
  "private": true,
  "publisher": "etienne-lescot",
  "files": [
    "out",
    "assets",
    "LICENSE.md",
    "README.md"
  ],
  "license": "MIT",
  "icon": "assets/logo.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/EtienneLescot/n8n-as-code"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "n8n-explorer",
          "title": "n8n",
          "icon": "assets/logo.png"
        }
      ]
    },
    "views": {
      "n8n-explorer": [
        {
          "id": "n8n-explorer.workflows",
          "name": "Workflows"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "n8n-explorer.workflows",
        "contents": "Welcome to n8n as code!\n\nTo get started, you need to configure your n8n instance details.\n\n[Configure](command:n8n.configure)",
        "when": "n8n.state == configuring"
      },
      {
        "view": "n8n-explorer.workflows",
        "contents": "Ready to sync your n8n workflows!\n\nClick the button below to start synchronizing workflows between your n8n instance and this workspace.\n\n[Initialize n8n as code](command:n8n.init)",
        "when": "n8n.state == uninitialized"
      },
      {
        "view": "n8n-explorer.workflows",
        "contents": "Settings have changed. Syncing is currently paused.\n\nClick the button below to apply the new settings and resume synchronization.\n\n[Apply Changes](command:n8n.applySettings)",
        "when": "n8n.state == settings-changed"
      }
    ],
    "commands": [
      {
        "command": "n8n.configure",
        "title": "n8n: Configure",
        "icon": "$(settings-gear)"
      },
      {
        "command": "n8n.switchInstance",
        "title": "n8n: Select Instance",
        "icon": "$(list-selection)"
      },
      {
        "command": "n8n.deleteInstance",
        "title": "n8n: Delete Saved Instance",
        "icon": "$(trash)"
      },
      {
        "command": "n8n.init",
        "title": "n8n: Initialize n8n as code",
        "icon": "$(rocket)"
      },
      {
        "command": "n8n.openBoard",
        "title": "Open in n8n",
        "icon": "$(browser)"
      },
      {
        "command": "n8n.openJson",
        "title": "Open File",
        "icon": "$(go-to-file)"
      },
      {
        "command": "n8n.openSplit",
        "title": "Open Split View",
        "icon": "$(split-horizontal)"
      },
      {
        "command": "n8n.pushWorkflow",
        "title": "Push",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "n8n.pullWorkflow",
        "title": "Pull",
        "icon": "$(cloud-download)"
      },
      {
        "command": "n8n.refresh",
        "title": "Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "n8n.findWorkflow",
        "title": "Find Workflow",
        "icon": "$(search)"
      },
      {
        "command": "n8n.openSettings",
        "title": "n8n: Open Settings",
        "icon": "$(gear)"
      },
      {
        "command": "n8n.initializeAI",
        "title": "Initialize AI Context",
        "icon": "$(sparkle)"
      },
      {
        "command": "n8n.applySettings",
        "title": "Apply n8n Settings",
        "icon": "$(check)"
      },
      {
        "command": "n8n.fetchWorkflow",
        "title": "Fetch",
        "icon": "$(refresh)"
      },
      {
        "command": "n8n.resolveConflict",
        "title": "Resolve Conflict",
        "icon": "$(warning)"
      },
      {
        "command": "n8n.spacer",
        "title": "n8n Spacer",
        "icon": "assets/spacer.png"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "n8n.applySettings",
          "group": "navigation@0",
          "when": "view == n8n-explorer.workflows && n8n.state == settings-changed"
        },
        {
          "command": "n8n.refresh",
          "group": "navigation@1",
          "when": "view == n8n-explorer.workflows && n8n.state == initialized"
        },
        {
          "command": "n8n.findWorkflow",
          "group": "navigation@2",
          "when": "view == n8n-explorer.workflows && n8n.state == initialized"
        },
        {
          "command": "n8n.spacer",
          "group": "navigation@3",
          "when": "view == n8n-explorer.workflows"
        },
        {
          "command": "n8n.configure",
          "group": "navigation@4",
          "when": "view == n8n-explorer.workflows"
        }
      ],
      "view/item/context": [
        {
          "command": "n8n.openJson",
          "group": "inline@1",
          "when": "viewItem =~ /workflow-(local|local-only|modified-local|modified-remote)/ && viewItem != workflow-conflict"
        },
        {
          "command": "n8n.openBoard",
          "group": "inline@2",
          "when": "viewItem =~ /workflow-(local|cloud-only|modified-remote)/ && viewItem != workflow-conflict"
        },
        {
          "command": "n8n.pushWorkflow",
          "group": "inline@3",
          "when": "viewItem =~ /workflow-(local|local-only|modified-local)/ && viewItem != workflow-conflict"
        },
        {
          "command": "n8n.pullWorkflow",
          "group": "inline@4",
          "when": "viewItem =~ /workflow-(local|local-only|cloud-only|modified-local|modified-remote)/ && viewItem != workflow-conflict"
        },
        {
          "command": "n8n.openBoard",
          "group": "1_open@1",
          "when": "viewItem =~ /workflow-(local|cloud-only|modified-remote)/"
        },
        {
          "command": "n8n.openJson",
          "group": "1_open@2",
          "when": "viewItem =~ /workflow-(local|local-only|modified-local)/"
        },
        {
          "command": "n8n.openSplit",
          "group": "1_open@3",
          "when": "viewItem =~ /workflow-(local|modified-local|modified-remote)/"
        },
        {
          "command": "n8n.pushWorkflow",
          "group": "2_sync@1",
          "when": "viewItem =~ /workflow-(local|local-only|modified-local)/ && viewItem != workflow-conflict"
        },
        {
          "command": "n8n.pullWorkflow",
          "group": "2_sync@2",
          "when": "viewItem =~ /workflow-(local|local-only|cloud-only|modified-local|modified-remote)/ && viewItem != workflow-conflict"
        }
      ]
    },
    "configuration": {
      "title": "n8n as Code",
      "properties": {
        "n8n.host": {
          "type": "string",
          "description": "Base URL of n8n instance"
        },
        "n8n.apiKey": {
          "type": "string",
          "description": "n8n API Key"
        },
        "n8n.syncFolder": {
          "type": "string",
          "default": "workflows",
          "description": "Local folder to sync workflows"
        },
        "n8n.projectId": {
          "type": "string",
          "description": "Project ID to sync (managed by the extension; use the Configure command to select)"
        },
        "n8n.projectName": {
          "type": "string",
          "description": "Project name to display (managed by the extension; use the Configure command to select)"
        }
      }
    }
  },
  "categories": [
    "AI",
    "Visualization",
    "Snippets"
  ],
  "keywords": [
    "n8n",
    "workflow",
    "workflows",
    "automation",
    "ai",
    "agent",
    "agents",
    "typescript",
    "json",
    "sync",
    "gitops",
    "langchain"
  ],
  "dependencies": {
    "@n8n-as-code/skills": "1.7.0",
    "n8nac": "1.5.5",
    "@reduxjs/toolkit": "^2.11.2",
    "http-proxy": "^1.18.1",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@types/http-proxy": "^1.17.17",
    "@types/node": "^18.0.0",
    "@types/vscode": "^1.85.0",
    "@types/ws": "^8.18.1",
    "esbuild": "^0.27.2",
    "tsx": "^4.19.3",
    "typescript": "^5.3.3"
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "compile": "tsc -b",
    "watch": "tsc -b -w",
    "package-bundle": "node esbuild.config.js",
    "copy-assets": "mkdir -p assets && cp ../../res/logo.png assets/ && cp ./res/spacer.png assets/",
    "build": "npm run compile && npm run copy-assets && npm run package-bundle",
    "clean": "rm -rf out assets tsconfig.tsbuildinfo",
    "test": "npm run compile && npx tsx --test tests/unit/*.test.ts"
  }
}
