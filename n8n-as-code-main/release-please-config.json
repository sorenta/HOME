{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "release-type": "node",
  "bump-minor-pre-major": true,
  "bump-patch-for-minor-pre-major": true,
  "separate-pull-requests": false,
  "group-pull-requests": true,
  "pull-request-title-pattern": "chore: release ${version}",
  "tag-separator": "@",
  "include-component-in-tag": true,
  "packages": {
    "packages/transformer": {
      "package-name": "@n8n-as-code/transformer",
      "component": "@n8n-as-code/transformer",
      "changelog-path": "CHANGELOG.md"
    },
    "packages/skills": {
      "package-name": "@n8n-as-code/skills",
      "component": "@n8n-as-code/skills",
      "changelog-path": "CHANGELOG.md"
    },
    "packages/cli": {
      "package-name": "n8nac",
      "component": "n8nac",
      "changelog-path": "CHANGELOG.md"
    },
    "packages/mcp": {
      "package-name": "@n8n-as-code/mcp",
      "component": "@n8n-as-code/mcp",
      "changelog-path": "CHANGELOG.md"
    },
    "packages/vscode-extension": {
      "package-name": "n8n-as-code",
      "component": "n8n-as-code",
      "changelog-path": "CHANGELOG.md"
    },
    "plugins/openclaw/n8n-as-code": {
      "package-name": "@n8n-as-code/n8nac",
      "component": "@n8n-as-code/n8nac",
      "changelog-path": "CHANGELOG.md"
    }
  },
  "plugins": [
    {
      "type": "node-workspace",
      "update-peer-dependencies": true
    }
  ]
}
